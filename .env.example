# ============================================================
# .env.example — Copy to .env.local and fill in real values
# DO NOT commit .env.local to version control
# ============================================================

# ----------------------------------------------------------
# Supabase — https://supabase.com/dashboard/project/_/settings/api
# ----------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Direct PostgreSQL connection used by Prisma (pooler or direct)
# Format: postgresql://postgres.[project-ref]:[password]@[host]:5432/postgres?sslmode=require
DATABASE_URL=postgresql://postgres:[password]@[host]:5432/postgres

# ----------------------------------------------------------
# Optional: analytics / monitoring
# ----------------------------------------------------------
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=yourdomain.com
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ----------------------------------------------------------
# Optional: AI features (Phase 3+)
# ----------------------------------------------------------
# OpenAI-compatible chat completions provider.
# DeepSeek example:
# AI_PROVIDER_BASE_URL=https://api.deepseek.com
# AI_PROVIDER_API_KEY=your_api_key_here
# AI_PROVIDER_MODEL=deepseek-v4-flash
# AI_INTERPRETATION_ENABLED=false

# ----------------------------------------------------------
# Transactional email — Resend
# ----------------------------------------------------------
# RESEND_API_KEY=re_xxx
# EMAIL_FROM=Mingli Atlas <newsletter@mail.mingliatlas.com>
# CONTACT_NOTIFICATION_EMAIL=you@example.com
# SUBSCRIPTION_TOKEN_SECRET=generate-a-long-random-value
