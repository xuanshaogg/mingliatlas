# ============================================================
# .env.example — Copy to .env.local and fill in real values
# DO NOT commit .env.local to version control
# ============================================================

# ----------------------------------------------------------
# Supabase — https://supabase.com/dashboard/project/_/settings/api
# ----------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Direct PostgreSQL connection used by Prisma (pooler or direct)
# Format: postgresql://postgres.[project-ref]:[password]@[host]:5432/postgres
DATABASE_URL=postgresql://postgres:[password]@[host]:5432/postgres

# ----------------------------------------------------------
# Optional: analytics / monitoring
# ----------------------------------------------------------
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=yourdomain.com
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ----------------------------------------------------------
# Optional: AI features (Phase 3+)
# ----------------------------------------------------------
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
